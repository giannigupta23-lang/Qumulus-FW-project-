<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f0f2f5; padding: 20px; }
        .container { max-width: 1200px; margin: auto; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .header { text-align: center; border-bottom: 3px solid #005073; padding-bottom: 20px; margin-bottom: 20px; }
        .logo { font-size: 28px; font-weight: bold; color: #005073; }
        
        /* Network Diagram Styles */
        .network-stack { display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 20px 0; }
        .node { background: #005073; color: white; padding: 10px 20px; border-radius: 4px; width: 80%; text-align: center; }
        .firewall-row { display: flex; gap: 20px; justify-content: center; margin: 20px 0; }
        .firewall { background: #d9534f; color: white; padding: 15px; border-radius: 50px; width: 100px; text-align: center; font-weight: bold; }
        
        /* Procurement Paths */
        .procurement-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; }
        .path-box { border: 1px solid #ccc; padding: 20px; border-radius: 8px; background: #f9f9f9; }
        .path-title { font-weight: bold; color: #005073; margin-bottom: 10px; border-bottom: 1px solid #ddd; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="logo">Qumulus AI</div>
        <div>Atlanta, GA | 128-Node B300 GPU Cluster</div>
    </div>

    <!-- Edge Security Layer -->
    <h3>Edge Security Layer</h3>
    <div class="firewall-row">
        <div class="firewall">FW 01</div>
        <div class="firewall">FW 02</div>
        <div class="firewall">FW 03</div>
    </div>

    <!-- Network Topology -->
    <div class="network-stack">
        <div class="node">Spines: 2x Nexus 9364E-SG2-O</div>
        <div class="node">Compute Fabric: Dual-Plane (16 Leafs, 8 Spines per plane)</div>
        <div class="node">Storage Leafs: 2x Nexus 9332D-GX2B (1.5 PB VAST Storage)</div>
        <div class="node">Compute: 128x UCS C880A Nodes</div>
        <div class="node">OOB Network: 8x Nexus 92348GC-FX3</div>
    </div>

    <!-- Procurement Paths -->
    <div class="procurement-grid">
        <div class="path-box">
            <div class="path-title">Neo Procurement Path</div>
            <ul>
                <li>Partners: Qumulus, Cirrascale, Massed Compute</li>
                <li>Model: Sell-through motion</li>
                <li>Licensing: BYOL Integration</li>
            </ul>
        </div>
        <div class="path-box">
            <div class="path-title">Enterprise Procurement Path</div>
            <ul>
                <li>Programs: EA (Enterprise Agreement), WPAS</li>
                <li>Model: Standard Cisco Enterprise</li>
                <li>Licensing: BYOL Integration</li>
            </ul>
        </div>
    </div>
</div>

</body>
</html>
